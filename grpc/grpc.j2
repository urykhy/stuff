#pragma once

{% set package=doc[0].package %}
{% set svc=doc[1] %}

#include <grpcpp/client_context.h>
#include <grpcpp/completion_queue.h>
#include <grpcpp/create_channel.h>
#include <grpcpp/security/credentials.h>
#include <grpcpp/security/server_credentials.h>
#include <grpcpp/server_builder.h>

#include "{{ package | capitalize }}.grpc.pb.h"

#include <threads/Asio.hpp>
#include <threads/Group.hpp>

#define AGRPC_BOOST_ASIO
#include <agrpc/client_rpc.hpp>
#include <agrpc/grpc_context.hpp>
#include <agrpc/register_awaitable_rpc_handler.hpp>
#include <agrpc/server_rpc.hpp>

namespace GRPC::{{ package | capitalize }} {

    class Server
    {
        using ContextPtr = std::shared_ptr<agrpc::GrpcContext>;
        {{ package }}::{{ svc.service }}::AsyncService m_Service;
        std::unique_ptr<grpc::Server>   m_Server;
        grpc::ServerBuilder             m_Builder;
        std::vector<ContextPtr>         m_Contexts;
        Threads::Group                  m_Thread;
        const unsigned                  m_ThreadCount;

        {% for m in svc.methods %}
        virtual boost::asio::awaitable<grpc::Status> Do{{ m.method }}({{ package }}::{{ m.request.type }}& aRequest, {{ package }}::{{ m.response.type }}& aResponse) {
            co_return grpc::Status(grpc::StatusCode::NOT_FOUND, "Method not implemented");
        }
        {% endfor %}

    public:
        Server(unsigned aThreadCount = 1)
        : m_ThreadCount(aThreadCount)
        {
            for (unsigned i = 0; i < m_ThreadCount; i++) {
                m_Contexts.push_back(std::make_shared<agrpc::GrpcContext>(m_Builder.AddCompletionQueue()));
            }
        }

        void Start(const std::string& aAddr)
        {
            m_Builder.AddListeningPort(aAddr, grpc::InsecureServerCredentials());
            m_Builder.RegisterService(&m_Service);
            m_Server = m_Builder.BuildAndStart();

            for (auto& sContext : m_Contexts) {
                {% for m in svc.methods %}
                {
                    using RPC = agrpc::ServerRPC<&{{ package }}::{{ svc.service }}::AsyncService::Request{{ m.method }}>;
                    agrpc::register_awaitable_rpc_handler<RPC>(
                        *sContext,
                        m_Service,
                        [this](RPC& aRPC, {{ package }}::{{ m.request.type }}& aRequest) -> boost::asio::awaitable<void> {
                            {{ package }}::{{ m.response.type }} sResponse;
                            grpc::Status sStatus = co_await Do{{ m.method }}(aRequest, sResponse);
                            co_await aRPC.finish(sResponse, sStatus, boost::asio::use_awaitable);
                        },
                        boost::asio::detached);
                }
                {% endfor %}
                m_Thread.start([this, sContext]() { prctl(PR_SET_NAME, "grpc:server"); sContext->run(); });
            }
        }

        void Stop()
        {
            m_Server->Shutdown();
            m_Thread.wait();
        }

        virtual ~Server() { Stop(); }
    };

    class Client
    {
        using ContextPtr = std::shared_ptr<agrpc::GrpcContext>;
        std::vector<ContextPtr> m_Contexts;
        {{ package }}::{{ svc.service}}::Stub m_Stub;
        Threads::Group          m_Thread;
        const unsigned          m_ThreadCount;
        std::atomic<unsigned>   m_Current{0};

    public:
        Client(const std::string& aAddr, unsigned aThreadCount = 1)
        : m_Stub(grpc::CreateChannel(aAddr, grpc::InsecureChannelCredentials()))
        , m_ThreadCount(aThreadCount)
        {
            for (unsigned i = 0; i < m_ThreadCount; i++) {
                m_Contexts.push_back(std::make_shared<agrpc::GrpcContext>());
            }
        }

        void Start()
        {
            for (auto& sContext : m_Contexts) {
                m_Thread.start(
                    [this, sContext] {
                        prctl(PR_SET_NAME, "grpc:client");
                        boost::asio::executor_work_guard<decltype(sContext->get_executor())> sWork{sContext->get_executor()};
                        sContext->run();
                    });
            }
        }

        void Stop()
        {
            for (auto& sContext : m_Contexts) {
                sContext->stop();
            }
            m_Thread.wait();
        }

        ~Client()
        {
            Stop();
        }

        {% for m in svc.methods %}
        boost::asio::awaitable<{{ package }}::{{ m.response.type }}> {{ m.method }}(const {{ package }}::{{ m.request.type }}& aRequest)
        {
            using RPC = agrpc::ClientRPC<&{{ package }}::{{ svc.service }}::Stub::PrepareAsync{{ m.method }}>;
            grpc::ClientContext sContext;
            sContext.set_deadline(std::chrono::system_clock::now() + std::chrono::milliseconds(100));

            {{ package }}::{{ m.response.type }} sResponse;
            const auto         sCurrent = m_Current.fetch_add(1, std::memory_order_relaxed) % m_Contexts.size();
            const grpc::Status sStatus =
                co_await RPC::request(*m_Contexts[sCurrent], m_Stub, sContext, aRequest, sResponse, boost::asio::use_awaitable);
            if (sStatus.ok()) {
                co_return sResponse;
            } else {
                throw std::runtime_error("{{ package | capitalize }}::Client: {{ m.method }} failed, status " + sStatus.error_message());
            }
        }
        {% endfor %}
    };
}
